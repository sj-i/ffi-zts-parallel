{
    "name": "sj-i/ffi-zts-parallel",
    "description": "PHP-side wrapper around pecl/parallel for use through sj-i/ffi-zts (NTS host -> embedded ZTS interpreter -> real OS threads).",
    "type": "composer-plugin",
    "license": "MIT",
    "keywords": ["ffi-zts", "parallel", "threads", "zts", "composer-plugin"],
    "authors": [
        {"name": "sj-i"}
    ],
    "require": {
        "php": ">=8.5,<8.6",
        "composer-plugin-api": "^2.0",
        "ext-ffi": "*",
        "sj-i/ffi-zts": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "SjI\\FfiZts\\Parallel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SjI\\FfiZts\\Parallel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "class": "SjI\\FfiZts\\Parallel\\ComposerPlugin",
        "ffi-zts-parallel": {
            "parallel-version": "1.2.12",
            "release-asset-format": "parallel-{parallel}-php{phpabi}-{arch}-{libc}.tar.gz"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "sj-i/ffi-zts": true,
            "sj-i/ffi-zts-parallel": true
        }
    }
}
